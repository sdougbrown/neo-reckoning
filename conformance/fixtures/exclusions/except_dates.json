      "expected": true
    },
    {
      "date": "2026-03-03",
      "expected": true
    },
    {
      "date": "2026-03-04",
      "expected": false
    },
    {
      "date": "2026-03-05",
      "expected": false
    },
    {
      "date": "2026-03-06",
      "expected": true
    },
    {
      "date": "2026-03-10",
      "expected": true
    }
  ],
  "expand": [
    {
      "from": "2026-03-01",
      "to": "2026-03-10",
      "expectedDates": [
        "2026-03-02",
        "2026-03-03",
        "2026-03-06",
        "2026-03-07",
