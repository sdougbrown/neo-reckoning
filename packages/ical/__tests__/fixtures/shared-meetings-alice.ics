PRODID:-//daywatch-cal tests//EN
BEGIN:VEVENT
UID:shared-sync
SUMMARY:Shared Sync
DESCRIPTION:Cross-calendar planning
DTSTART:20260402T150000Z
DTEND:20260402T160000Z
LOCATION:Room 500
ORGANIZER;CN=Alice Example:mailto:alice@example.com
ATTENDEE;CN=Alice Example;ROLE=REQ-PARTICIPANT;PARTSTAT=ACCEPTED:mailto:alice@example.com
ATTENDEE;CN=Bob Example;ROLE=OPT-PARTICIPANT;PARTSTAT=TENTATIVE:mailto:bob@example.com
END:VEVENT
BEGIN:VEVENT
UID:shared-weekly
SUMMARY:Shared Weekly
DESCRIPTION:Recurring shared check-in
DTSTART:20260406T140000Z
DTEND:20260406T143000Z
RRULE:FREQ=WEEKLY;BYDAY=MO;COUNT=3
ORGANIZER;CN=Alice Example:mailto:alice@example.com
ATTENDEE;CN=Alice Example;ROLE=REQ-PARTICIPANT;PARTSTAT=ACCEPTED:mailto:alice@example.com
ATTENDEE;CN=Bob Example;ROLE=REQ-PARTICIPANT;PARTSTAT=NEEDS-ACTION:mailto:bob@example.com
END:VEVENT
BEGIN:VEVENT
UID:alice-focus
SUMMARY:Alice Focus
DTSTART:20260402T170000Z
DTEND:20260402T180000Z
